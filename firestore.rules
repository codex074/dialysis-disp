rules_version = '2';

// ⚠️ ข้อจำกัดสำคัญ: แอปนี้ไม่ใช้ Firebase Auth (ตามที่ผู้ใช้ต้องการเก็บ user เองใน Firestore)
// จึงไม่สามารถใช้ request.auth ในการป้องกันได้ — กฎด้านล่างเปิดให้อ่าน/เขียนได้ทั้งหมด
// เหมาะกับการใช้งานภายใน/ทดสอบเท่านั้น ห้ามใช้กับข้อมูลผู้ป่วยจริงบนอินเทอร์เน็ตสาธารณะ
//
// แนวทางเสริมความปลอดภัย (follow-up ที่แนะนำ):
//   1) เปิด Firebase App Check (reCAPTCHA) เพื่อกันการเรียกจากนอกแอป
//   2) จำกัดการเข้าถึงด้วย IP allowlist ผ่าน reverse proxy / Cloud Functions
//   3) ถ้าต้องการความปลอดภัยเต็มรูปแบบ ให้พิจารณาเปิดใช้ Firebase Auth ภายหลัง
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
